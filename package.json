{
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.7",
    "@changesets/cli": "^2.29.7",
    "@types/node": "catalog:",
    "commitizen": "^4.3.1",
    "commitlint": "19.8.1",
    "commitlint-config-gitmoji": "^2.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "turbo": "^2.5.8",
    "typescript": "catalog:",
    "zod": "catalog:"
  },
  "engines": {
    "node": "22.20.0"
  },
  "license": "MIT",
  "name": "flemme-monorepo",
  "packageManager": "pnpm@10.18.3",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "changeset": "changeset",
    "clear:modules": "npx npkill",
    "dev": "turbo dev",
    "init": "pnpm install && find . -name '.env.example' -exec sh -c 'cp \"$1\" \"${1%.example}\"' sh {} \\;",
    "prepare": "husky",
    "release": "pnpm changeset && pnpm changeset version",
    "start": "turbo start",
    "test": "turbo test",
    "test:format": "biome format .",
    "test:lint": "biome lint ."
  },
  "version": "1.0.0"
}

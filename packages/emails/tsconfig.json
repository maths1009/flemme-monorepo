{
  "compilerOptions": {
    "baseUrl": "./emails",
    "composite": false,
    "noEmit": false,
    "outDir": "./dist",
    "declaration": true,
    "module": "CommonJS",
    "moduleResolution": "node",
    "skipLibCheck": true,
    "strict": true,
    "strictNullChecks": true
  },
  "exclude": ["node_modules", ".react-email"],
  "extends": "@flemme/ts-config/react-library.json",
  "include": ["index.ts", "emails/**/*"]
}
